{
  "palette": {
    "ink": "#17110C",
    "ivory": "#FFF8EE",
    "bordeaux": "#7F1734",
    "bordeaux_dark": "#4A0C1D",
    "gold": "#C99A43",
    "gold_light": "#F0D38A",
    "blush": "#E8B7AA",
    "charcoal": "#2A2119",
    "success": "#3F7A57",
    "white": "#FFFFFF"
  },
  "fonts": {
    "display": "'Cormorant Garamond', serif",
    "display_weight": "500",
    "body": "'Manrope', sans-serif",
    "utility": "'Manrope', sans-serif",
    "google_fonts_url": "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap"
  },
  "radius": {
    "sm": "6px",
    "md": "12px",
    "lg": "24px",
    "pill": "999px"
  },
  "shadow": {
    "soft": "0 20px 60px -20px rgba(23,17,12,0.25)",
    "lift": "0 30px 80px -25px rgba(23,17,12,0.35)",
    "glow": "0 0 0 1px rgba(201,154,67,0.35)"
  },
  "spacing": {
    "section_y": "8rem",
    "section_y_mobile": "4.5rem"
  },
  "motion": {
    "speed": "1",
    "ease": "cubic-bezier(0.16, 1, 0.3, 1)",
    "lenis_duration": "1.1"
  },
  "button": {
    "style": "jewel-outline",
    "radius": "pill",
    "letter_spacing": "0.04em"
  },
  "glass": {
    "bg": "rgba(255,248,238,0.72)",
    "border": "rgba(201,154,67,0.35)",
    "blur": "18px"
  }
}
