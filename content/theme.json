{
  "palette": {
    "ink": "#2A0F16",
    "ivory": "#FBF5EC",
    "bordeaux": "#7A2438",
    "bordeaux_dark": "#4E1523",
    "gold": "#B8874A",
    "gold_light": "#E4C89A",
    "blush": "#E7C6C0",
    "charcoal": "#2A2420",
    "success": "#4C7A5A",
    "white": "#FFFFFF"
  },
  "fonts": {
    "display": "'Fraunces', serif",
    "display_weight": "460",
    "body": "'Manrope', sans-serif",
    "utility": "'Manrope', sans-serif",
    "google_fonts_url": "https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..700&family=Manrope:wght@400;500;600;700;800&display=swap"
  },
  "radius": {
    "sm": "6px",
    "md": "14px",
    "lg": "28px",
    "pill": "999px"
  },
  "shadow": {
    "soft": "0 20px 60px -20px rgba(42,15,22,0.25)",
    "lift": "0 30px 80px -25px rgba(42,15,22,0.35)",
    "glow": "0 0 0 1px rgba(184,135,74,0.35)"
  },
  "spacing": {
    "section_y": "8rem",
    "section_y_mobile": "4.5rem"
  },
  "motion": {
    "speed": "1",
    "ease": "cubic-bezier(0.16, 1, 0.3, 1)",
    "lenis_duration": "1.1"
  },
  "button": {
    "style": "thread-outline",
    "radius": "pill",
    "letter_spacing": "0.04em"
  },
  "glass": {
    "bg": "rgba(251,245,236,0.65)",
    "border": "rgba(184,135,74,0.35)",
    "blur": "18px"
  }
}
